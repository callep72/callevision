mqtt:
  host: 192.168.1.50
  port: 1883
  username: callevision
  password: changeme
  client_id: callevision-bridge

paths:
  runtime_pages: /home/calle/projects/callevision/runtime/pages
  templates: /home/calle/projects/callevision/templates

teletext:
  service_name: callevision-teletext
  reload_debounce_ms: 750

bus_departures:
  api_key: your-resrobot-v2.1-key
  stop_id: ""              # hitta med: python scripts/fetch-bus-departures.py --find-stop "Gribbylunds centrum"
  stop_name: "Gribbylunds centrum"
  lines:
    - "605"
    - "609"
    - "615"
